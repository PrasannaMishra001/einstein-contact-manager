# ── Database ─────────────────────────────────────────────────────────────────
# LOCAL DEV: use SQLite — no server to install, the file is created on first run.
# This is the quickest way to get the backend booting locally.
DATABASE_URL=sqlite+aiosqlite:///./einstein_dev.db

# PRODUCTION (Neon PostgreSQL) — comment out the SQLite line above and use these.
# Get from: https://neon.tech → New Project → Connection String
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?ssl=require
# DATABASE_URL_SYNC=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Groq (Llama 3.3 70B — natural-language search, dedup, tagging) ────────────
# Get from: https://console.groq.com/keys   (free tier)
# This is the main AI key — without it, AI search and smart dedup stop working.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── Google Gemini AI (business-card photo OCR only) ───────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Cloudinary (Photo Storage) ────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Resend (Email) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ── Google Contacts OAuth ─────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/google/callback

# ── App Config ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
APP_NAME=Einstein Contact Manager

# ── Webhook Security ──────────────────────────────────────────────────────────
WEBHOOK_SECRET=your-webhook-secret-here
